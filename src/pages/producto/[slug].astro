---
import Layout from '../../layouts/Layout.astro';
import { getSlugsProductos, getProductoBySlug } from '../../lib/queries';
import { urlFor } from '../../lib/sanity';
import { COLORES_HEX } from '../../lib/colores';

export async function getStaticPaths() {
  const slugs = await getSlugsProductos();
  return slugs.map(({ slug }) => ({ params: { slug: slug.current } }));
}

const { slug } = Astro.params;
const producto = await getProductoBySlug(slug!);

if (!producto) return Astro.redirect('/tienda');

const imagenesUrls = (producto.imagenes ?? []).map(img =>
  urlFor(img).width(900).height(1200).fit('crop').url()
);
const imagenPrincipal = imagenesUrls[0] ?? null;

const precioTransferencia = Math.round(producto.precio * 0.9);
const colores = producto.colores ?? [];
const talles = producto.talles ?? [];
const tieneVariasFotos = imagenesUrls.length > 1;
---

<Layout title={producto.nombre}>
  <div class="max-w-6xl mx-auto px-4 py-10">
    <!-- Breadcrumb -->
    <nav class="text-xs text-sand tracking-wide mb-8 flex flex-wrap gap-1 items-center">
      <a href="/tienda" class="hover:text-dark transition-colors">Tienda</a>
      {producto.categoria && (
        <>
          <span>/</span>
          <a href={`/${producto.categoria.slug.current}`} class="hover:text-dark transition-colors">
            {producto.categoria.nombre}
          </a>
        </>
      )}
      <span>/</span>
      <span class="text-dark">{producto.nombre}</span>
    </nav>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 lg:gap-20">
      <!-- Galería -->
      <div class="flex flex-col gap-3">
        <!-- Imagen principal con flechas -->
        <div class="aspect-[3/4] bg-sand-light overflow-hidden relative">
          {imagenPrincipal ? (
            <img
              id="imagen-principal"
              src={imagenPrincipal}
              alt={producto.nombre}
              class="w-full h-full object-cover"
            />
          ) : (
            <div class="w-full h-full flex items-center justify-center text-sand text-xs tracking-widest uppercase">
              Sin imagen
            </div>
          )}

          {/* Flechas de navegación */}
          {tieneVariasFotos && (
            <>
              <button
                id="prev-img"
                class="absolute left-2 top-1/2 -translate-y-1/2 w-9 h-9 bg-offwhite/80 hover:bg-offwhite flex items-center justify-center transition-colors z-10"
                aria-label="Imagen anterior"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <polyline points="15 18 9 12 15 6"/>
                </svg>
              </button>
              <button
                id="next-img"
                class="absolute right-2 top-1/2 -translate-y-1/2 w-9 h-9 bg-offwhite/80 hover:bg-offwhite flex items-center justify-center transition-colors z-10"
                aria-label="Siguiente imagen"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <polyline points="9 18 15 12 9 6"/>
                </svg>
              </button>
              <!-- Indicadores de punto -->
              <div class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-1.5 z-10">
                {imagenesUrls.map((_, i) => (
                  <span
                    class={`dot-indicator w-1.5 h-1.5 rounded-full transition-colors ${i === 0 ? 'bg-dark' : 'bg-dark/30'}`}
                    data-index={i}
                  />
                ))}
              </div>
            </>
          )}

          {/* Datos para JS */}
          <div id="gallery-data" data-images={JSON.stringify(imagenesUrls)} class="hidden" />
        </div>

        {/* Miniaturas (referencia visual, las flechas son el nav principal) */}
        {tieneVariasFotos && (
          <div class="flex gap-2 overflow-x-auto pb-1">
            {imagenesUrls.map((url, i) => (
              <button
                class={`thumbnail-btn flex-shrink-0 w-20 h-24 overflow-hidden border-2 transition-colors ${i === 0 ? 'border-dark' : 'border-transparent hover:border-dark'}`}
                data-index={i}
                aria-label={`Ver imagen ${i + 1}`}
              >
                <img src={url} alt={`${producto.nombre} ${i + 1}`} class="w-full h-full object-cover" />
              </button>
            ))}
          </div>
        )}
      </div>

      <!-- Detalle -->
      <div class="flex flex-col">
        {producto.categoria && (
          <a
            href={`/${producto.categoria.slug.current}`}
            class="text-xs tracking-widest uppercase text-sand hover:text-terracotta transition-colors mb-3"
          >
            {producto.categoria.nombre}
          </a>
        )}
        <h1 class="font-serif text-4xl font-light mb-4">{producto.nombre}</h1>

        <!-- Precios -->
        <div class="flex flex-wrap items-center gap-3 mb-2">
          <p class="text-2xl text-terracotta">$ {producto.precio.toLocaleString('es-AR')}</p>
          <div class="border border-terracotta/40 px-3 py-1.5 bg-terracotta/5">
            <p class="text-sm text-terracotta">$ {precioTransferencia.toLocaleString('es-AR')} <span class="text-xs">con transferencia</span></p>
          </div>
        </div>
        <p class="text-xs text-sand mb-6 tracking-wide">10% OFF abonando con transferencia bancaria</p>

        {producto.descripcion && (
          <p class="text-sm text-dark/70 leading-relaxed mb-6">{producto.descripcion}</p>
        )}

        <!-- Selector de talles -->
        {talles.length > 0 && (
          <div class="mb-6">
            <p class="text-xs tracking-widest uppercase mb-3">Talle</p>
            <div class="flex flex-wrap gap-2">
              {talles.map(talle => (
                <button
                  class="talle-btn border border-sand px-4 py-2.5 text-sm hover:border-dark transition-colors min-w-[3rem]"
                  data-talle={talle}
                >
                  {talle}
                </button>
              ))}
            </div>
          </div>
        )}

        <!-- Selector de colores -->
        {colores.length > 0 && (
          <div class="mb-8">
            <p class="text-xs tracking-widest uppercase mb-3">
              Color <span id="color-label" class="normal-case font-normal text-sand ml-1"></span>
            </p>
            <div class="flex flex-wrap gap-2.5">
              {colores.map(color => (
                <button
                  class="color-btn w-7 h-7 rounded-full border-2 border-transparent ring-2 ring-transparent hover:ring-sand transition-all"
                  style={`background-color: ${COLORES_HEX[color] ?? '#ccc'}`}
                  data-color={color}
                  title={color}
                  aria-label={color}
                />
              ))}
            </div>
          </div>
        )}

        <!-- Botón WhatsApp (siempre activo) -->
        <button
          id="btn-whatsapp"
          class="w-full bg-terracotta text-offwhite py-4 text-xs tracking-widest uppercase flex items-center justify-center gap-3 hover:bg-terracotta-dark transition-colors"
          data-nombre={producto.nombre}
          data-precio={producto.precio}
          data-precio-transf={precioTransferencia}
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Comprar por WhatsApp
        </button>

        <p class="text-xs text-sand text-center mt-3 tracking-wide">
          Te redirigimos a WhatsApp para completar tu pedido
        </p>
      </div>
    </div>
  </div>
</Layout>

<script>
  const WHATSAPP = '5491173742763';
  let talleSeleccionado: string | null = null;
  let colorSeleccionado: string | null = null;
  let currentIndex = 0;

  const btnWhatsapp = document.getElementById('btn-whatsapp') as HTMLButtonElement;
  const colorLabel = document.getElementById('color-label');
  const talleBtns = document.querySelectorAll<HTMLButtonElement>('.talle-btn');
  const colorBtns = document.querySelectorAll<HTMLButtonElement>('.color-btn');
  const thumbnailBtns = document.querySelectorAll<HTMLButtonElement>('.thumbnail-btn');
  const imgPrincipal = document.getElementById('imagen-principal') as HTMLImageElement | null;
  const dots = document.querySelectorAll<HTMLElement>('.dot-indicator');

  const galleryData = document.getElementById('gallery-data') as HTMLElement | null;
  const imagenesUrls: string[] = JSON.parse(galleryData?.dataset.images ?? '[]');

  // ── Galería con flechas ──────────────────────────────────────────
  function goTo(index: number) {
    if (imagenesUrls.length === 0) return;
    currentIndex = (index + imagenesUrls.length) % imagenesUrls.length;
    if (imgPrincipal) imgPrincipal.src = imagenesUrls[currentIndex];
    thumbnailBtns.forEach((b, i) => {
      b.classList.toggle('border-dark', i === currentIndex);
      b.classList.toggle('border-transparent', i !== currentIndex);
    });
    dots.forEach((d, i) => {
      d.classList.toggle('bg-dark', i === currentIndex);
      d.classList.toggle('bg-dark/30', i !== currentIndex);
    });
  }

  document.getElementById('prev-img')?.addEventListener('click', () => goTo(currentIndex - 1));
  document.getElementById('next-img')?.addEventListener('click', () => goTo(currentIndex + 1));

  thumbnailBtns.forEach((btn, i) => {
    btn.addEventListener('click', () => goTo(i));
  });

  // ── Talles ───────────────────────────────────────────────────────
  talleBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      talleBtns.forEach(b => {
        b.classList.remove('bg-dark', 'text-offwhite', 'border-dark');
        b.classList.add('border-sand');
      });
      btn.classList.add('bg-dark', 'text-offwhite', 'border-dark');
      btn.classList.remove('border-sand');
      talleSeleccionado = btn.dataset.talle ?? null;
    });
  });

  // ── Colores ──────────────────────────────────────────────────────
  colorBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      colorBtns.forEach(b => {
        b.classList.remove('ring-dark', 'border-white');
        b.classList.add('ring-transparent', 'border-transparent');
      });
      btn.classList.add('ring-dark', 'border-white');
      btn.classList.remove('ring-transparent', 'border-transparent');
      colorSeleccionado = btn.dataset.color ?? null;
      if (colorLabel) colorLabel.textContent = `— ${colorSeleccionado}`;
    });
  });

  // ── WhatsApp ─────────────────────────────────────────────────────
  btnWhatsapp?.addEventListener('click', () => {
    const nombre = btnWhatsapp.dataset.nombre ?? '';
    const precio = Number(btnWhatsapp.dataset.precio).toLocaleString('es-AR');
    const precioTransf = Number(btnWhatsapp.dataset.precioTransf).toLocaleString('es-AR');
    const url = window.location.href;

    let mensaje = `Hola! Me gustaría hacer un pedido:\n\n👗 *${nombre}*\n`;
    mensaje += `📏 Talle: ${talleSeleccionado ?? 'No especificado'}\n`;
    mensaje += `🎨 Color: ${colorSeleccionado ?? 'No especificado'}\n`;
    mensaje += `💰 Precio: $${precio}\n`;
    mensaje += `💸 Con transferencia: $${precioTransf} (-10%)\n`;
    mensaje += `🔗 ${url}`;

    window.open(`https://wa.me/${WHATSAPP}?text=${encodeURIComponent(mensaje)}`, '_blank');
  });
</script>
